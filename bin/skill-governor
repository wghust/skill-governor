// src/bin.ts
var runtimeProcess4 = globalThis.process;
void main(runtimeProcess4?.argv ?? []).catch((error) => {
  console.error(error);
  if (runtimeProcess4) {
    runtimeProcess4.exitCode = 1;
  }
});
