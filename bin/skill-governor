    } catch (error) {
      const workflowError = error instanceof GovernanceWorkflowError || error instanceof StoreResolutionError ? error : null;
      emitResult(
        failure(
          workflowError?.code ?? "PROJECTION_FAILED",
          error instanceof Error ? error.message : "Failed to generate runtime projections",
          normalizeDetails4(workflowError?.details)
        ),
        resolveFormat(options.format),
        renderFailureText9
      );
    }
  });
  return command;
}
async function resolveProjectionRegistry(storeRoot, options) {
  if (options.refresh === true) {
    const registry2 = await scanAndNormalizeRegistry(buildRegistryScanOptions(options));
    await writeRegistryDocument(storeRoot, registry2);
    return registry2;
  }
  const existing = await readRegistryDocument(storeRoot);
  if (existing !== null) {
    return existing;
  }
  const registry = await scanAndNormalizeRegistry(buildRegistryScanOptions(options));
  await writeRegistryDocument(storeRoot, registry);
  return registry;
}
function renderProjectionText(result) {
  if (!result.ok) {
    return renderFailureText9(result);
  }
  const providers = result.data.providers.map(
    (projection) => `${projection.provider}: ${projection.includedSkills.length} included / ${projection.excludedSkills.length} excluded`
  );
  return [
    `Generated at: ${result.data.generatedAt}`,
    `Active profile: ${result.data.activeProfile ?? "none"}`,
    `Plan: ${result.data.planId ?? "none"}`,
    `Providers: ${providers.join(", ") || "none"}`
  ];
}
