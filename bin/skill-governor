// src/cli.ts
var runtimeProcess2 = globalThis.process;
var StoreResolutionError = class extends Error {
  constructor(code, message, details) {
    super(message);
    this.name = "StoreResolutionError";
    this.code = code;
    this.details = details;
  }
};
function buildCli() {
  const program2 = new Command().name("skill-governor").description("AI-native skill governance CLI").showHelpAfterError();
  registerListCommand(program2);
  registerInspectCommand(program2);
  registerAuditCommand(program2);
  registerDedupeCommand(program2);
  registerClusterCommand(program2);
  registerOptimizeCommand(program2);
  registerApplyCommand(program2);
  registerRollbackCommand(program2);
  registerProfileUseCommand(program2);
  registerProjectionCommand(program2);
  registerReportCommand(program2);
  return program2;
}
function resolveFormat(value) {
  return value === "json" ? "json" : "text";
}
function resolveWorkspaceRoot(options) {
  return options.workspaceRoot?.trim() || runtimeProcess2?.cwd?.() || ".";
}
function resolveHomeDir(options) {
  return options.homeDir?.trim() || (0, import_node_os2.homedir)();
}
function normalizeListOption(value) {
  if (value === void 0) {
    return [];
  }
  const items = Array.isArray(value) ? value : [value];
  return items.flatMap((entry) => entry.split(",")).map((entry) => entry.trim()).filter((entry) => entry.length > 0);
}
function normalizeProviderSelection(value) {
  const validProviders = ["cursor", "codex", "claude"];
  const selected = normalizeListOption(value).filter(
    (item) => validProviders.includes(item)
  );
  return selected.length > 0 ? [...new Set(selected)] : void 0;
}
function normalizeSourceScopeSelection(value) {
  const selected = normalizeListOption(value).filter(
    (item) => item === "user" || item === "workspace"
  );
  return selected.length > 0 ? [...new Set(selected)] : void 0;
}
function buildRegistryScanOptions(options) {
  return {
    workspaceRoot: resolveWorkspaceRoot(options),
    homeDir: resolveHomeDir(options),
    providers: normalizeProviderSelection(options.provider),
    sourceScopes: normalizeSourceScopeSelection(options.sourceScope)
  };
}
function resolveGovernanceStoreRoot(options) {
  if (options.storeRoot?.trim()) {
    return options.storeRoot.trim();
  }
  if (options.scope !== "user" && options.scope !== "workspace") {
    throw new StoreResolutionError(
      "STORE_ROOT_REQUIRED",
      "Use --store-root or select a scope with --scope user|workspace."
    );
  }
  const workspaceRoot = resolveWorkspaceRoot(options);
  const storeRoot = resolveSkillGovernorRoot(
    options.scope,
    resolveHomeDir(options),
    workspaceRoot
  );
  const legacyStoreRoot = detectLegacyWorkspaceSkillGovernorRoot(workspaceRoot, storeRoot);
  if (legacyStoreRoot !== null) {
    throw new StoreResolutionError(
      "LEGACY_STORE_FOUND",
      `Legacy workspace-local store detected at ${legacyStoreRoot}. Migrate it to ${storeRoot} or rerun with --store-root to select the legacy location explicitly.`,
      {
        legacyStoreRoot,
        storeRoot,
        workspaceRoot
      }
    );
  }
  return storeRoot;
}
function emitResult(result, format, renderText) {
  if (format === "json") {
    console.log(JSON.stringify(result, null, 2));
    return;
  }
  for (const line of renderText(result)) {
    console.log(line);
  }
}

// src/index.ts
var runtimeProcess3 = globalThis.process;
