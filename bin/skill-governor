// src/commands/report.ts
function registerReportCommand(program2) {
  const command = program2.command("report").description("Generate a governance report").option("--scope <scope>", "target scope for runtime projection summary", "workspace").option("--store-root <path>", "store root override for runtime projection summary").option("--workspace-root <path>", "workspace root to scan").option("--home-dir <path>", "home directory to scan").option("--provider <provider...>", "limit scanning to one or more providers").option("--source-scope <scope...>", "limit scanning to user or workspace scope").option("--format <format>", "output format", "text");
  command.action(async (options) => {
    try {
      const registry = await scanAndNormalizeRegistry(buildRegistryScanOptions(options));
      const audit = createAuditSummary(registry.skills);
      const duplicateGroups = findDuplicateGroups(registry.skills);
      const clusters = createSkillClusters(registry.skills);
      const runtimeProjection = await readRuntimeProjectionSet(resolveTargetStoreRoot5(options));
      emitResult(
        success({
          generatedAt: registry.generatedAt,
          workspaceRoot: registry.workspaceRoot,
          audit,
          duplicateGroups: duplicateGroups.groups,
          clusters,
          runtimeProjection: runtimeProjection === null ? null : {
            activeProfile: runtimeProjection.activeProfile,
            planId: runtimeProjection.planId,
            byProvider: Object.fromEntries(runtimeProjection.providers.map((projection) => [
              projection.provider,
              {
                included: projection.includedSkills.length,
                excluded: projection.excludedSkills.length
              }
            ]))
          }
        }),
        resolveFormat(options.format),
        renderReportText
      );
    } catch (error) {
      const workflowError = error instanceof StoreResolutionError ? error : null;
      emitResult(
        failure(
          workflowError?.code ?? "REPORT_FAILED",
          error instanceof Error ? error.message : "Failed to generate report",
          workflowError?.details
        ),
        resolveFormat(options.format),
        renderFailureText10
      );
    }
  });
  return command;
}
function renderReportText(result) {
  if (!result.ok) {
    return renderFailureText10(result);
  }
  const projectionSummary = result.data.runtimeProjection === null ? "none" : Object.entries(result.data.runtimeProjection.byProvider).map(([provider, counts]) => `${provider}: ${counts.included} included / ${counts.excluded} excluded`).join(", ") || "none";
  return [
    `Workspace: ${result.data.workspaceRoot}`,
    `Generated at: ${result.data.generatedAt}`,
    `Total skills: ${result.data.audit.totalSkills}`,
    `Duplicate groups: ${result.data.duplicateGroups.length}`,
    `Clusters: ${result.data.clusters.domainCount} domains / ${result.data.clusters.keywordCount} keyword clusters`,
    `Warnings: ${result.data.audit.warningCount}`,
    `Runtime projection: ${projectionSummary}`
  ];
}
function renderFailureText10(result) {
  return [`${result.error.code}: ${result.error.message}`];
}
function resolveTargetStoreRoot5(options) {
  return resolveGovernanceStoreRoot(options);
}

